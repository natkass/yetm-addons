<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_transfer_request_confirm_wizard_form" model="ir.ui.view">
        <field name="name">transfer.request.confirm.wizard.form</field>
        <field name="model">transfer.request.confirm.wizard</field>
        <field name="arch" type="xml">
            <form string="Warning">
                <sheet>
                    <div class="alert alert-warning" role="alert">
                        <field name="message" nolabel="1" readonly="1"/>
                    </div>
                    <field name="transfer_request_id" invisible="1"/>
                    <field name="action_type" invisible="1"/>
                </sheet>
                <footer>
                    <button name="action_proceed"
                            string="Yes, Proceed"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
