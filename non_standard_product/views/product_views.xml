<odoo>
    <record id="view_product_template_form_inherit_config_summary" model="ir.ui.view">
        <field name="name">product.template.form.inherit.config.summary</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook/page[@name='general_information']" position="after">
                <page string="Non-Standard Details" invisible="product_tag_ids not in ['Non-Standard']">
                    <field name="config_summary"  nolabel="1" readonly="1" widget="text"/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>