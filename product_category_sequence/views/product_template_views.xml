<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Inherit Tree View -->
    <record id="view_product_template_tree_inherit_sequence" model="ir.ui.view">
        <field name="name">product.template.tree.inherit.sequence</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//tree/field[@name='default_code']" position="after">
                <field name="category_sequence"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit Form View -->
    <record id="view_product_template_form_inherit_sequence" model="ir.ui.view">
        <field name="name">product.template.form.inherit.sequence</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='default_code']" position="after">
                <field name="category_sequence"/>
            </xpath>
        </field>
    </record>
    <record id="view_product_category_form_inherit_sequence" model="ir.ui.view">
        <field name="name">product.category.form.inherit.sequence.prefix</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parent_id']" position="after">
                <field name="sequence_prefix"/>
            </xpath>
        </field>
    </record>

</odoo>
