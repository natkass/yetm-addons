        <!-- Dukem Foam Quilting Production Picking Type -->
        <record id="picking_type_dukem_foam" model="stock.picking.type">
            <field name="name">Foam Quilting Production</field>
            <field name="code">mrp_operation</field>
            <field name="sequence_code">DKF</field>
            <field name="sequence">10</field>
            <field name="use_create_lots">False</field>
            <field name="use_existing_lots">True</field>
            <field name="default_location_src_id" ref="stock.stock_location_stock"/>
            <field name="default_location_dest_id" ref="stock.stock_location_stock"/>
            <field name="warehouse_id" ref="stock.warehouse0"/>
