<odoo>
    <record id="view_target_achived_manager_form" model="ir.ui.view">
        <field name="name">target.achieve.manager.form</field>
        <field name="model">target.achieve.manager</field>
        <field name="arch" type="xml">
            <form string="Account Manager Target">
                
                <sheet>
                    <h1><field name="name"/></h1>
                
                    <group>
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="acc_man_id" options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="acc_man_target" widget="monetary"/>
                            <field name="time_span"/>
                            <field name="time_span_label" readonly="1"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            
                        </group>
                        <group>
                            <field name="acc_man_achieved_amt"
                                   widget="monetary"/>
                            <field name="acc_man_achieved_percent" widget="progressbar" 
                                    options="{'max_field': '100'}"/>
                            
                            <field name="name" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Target Records">
                            <field name="target_record_ids" readonly="1">
                                <tree>
                                    <field name="franchisee_id"/>
                                    <field name="franchisee_target"/>
                                    <field name="franchisee_achieved_amt"/>
                                    <field name="time_span_label"/>
                                    <field name="franchisee_achieved_percent" widget="progressbar" 
                                                options="{'max_field': '100'}"/>

                                </tree>
                            </field>
                        </page>
                    </notebook>
                    
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
                
            </form>
        </field>
    </record>

    <record id="view_target_achived_manager_tree" model="ir.ui.view">
        <field name="name">target.achieve.manager.tree</field>
        <field name="model">target.achieve.manager</field>
        <field name="arch" type="xml">
            <tree>
                <field name="acc_man_id"/>
                <field name="acc_man_achieved_amt" widget="monetary"/>
                <field name="acc_man_target" force_save="1"/>
               
                <field name="time_span_label"/>
                <field name="acc_man_achieved_percent" widget="progressbar" 
                                    options="{'max_field': '100'}"/>
                
            </tree>
        </field>
    </record>

    <record id="action_target_achived_manager" model="ir.actions.act_window">
        <field name="name">Account Manager Target</field>
        <field name="res_model">target.achieve.manager</field>
        <field name="view_mode">tree,form</field>
    </record>

    
    <menuitem id="menu_account_manager_customer_root"
              name="Account Manager Target"
              parent="target_achieve_menu_sales_target"
              action="action_target_achived_manager"
              groups="sales_target_vs_achievement_group_sales_target_user"
              
              sequence="1"/>
</odoo>
