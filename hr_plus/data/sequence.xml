<odoo>
  <data noupdate="1">
    <record id="seq_hr_overtime" model="ir.sequence">
      <field name="name">Overtime</field>
      <field name="code">hr.overtime</field>
      <field name="prefix">OT/</field>
      <field name="padding">4</field>
    </record>
  </data>

  <data noupdate="1">
    <record id="seq_hr_incentive" model="ir.sequence">
      <field name="name">Incentive</field>
      <field name="code">hr.incentive</field>
      <field name="prefix">INC/</field>
      <field name="padding">4</field>
    </record>
  </data> 

  <data noupdate="1">
    <record id="seq_hr_daily_allowance" model="ir.sequence">
      <field name="name">Daly Allowance</field>
      <field name="code">hr.daily.allowance</field>
      <field name="prefix">DA-AL/</field>
      <field name="padding">4</field>
    </record>
  </data> 

  <data noupdate="1">
    <record id="seq_hr_driver_incentive" model="ir.sequence">
      <field name="name">Driver Incentive</field>
      <field name="code">hr.driver.incentive</field>
      <field name="prefix">DR-IN/</field>
      <field name="padding">4</field>
    </record>
  </data> 

  <data noupdate="1">
