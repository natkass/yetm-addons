<odoo>
  <record id="view_hr_overtime_form" model="ir.ui.view">
    <field name="name">hr.overtime.form</field>
    <field name="model">hr.overtime</field>
    <field name="arch" type="xml">
      <form string="Overtime Request">
        <header>
            <button name="action_submit" type="object" string="Submit"
                    invisible= "state != 'draft'" 
                    groups="hr_plus.group_hr_plus_overtime_submit"
                    class="btn-primary"/>
                    
            <button name="action_verify" type="object" string="Verify"
                    invisible= "state != 'submitted'" 
                    groups="hr_plus.group_hr_plus_overtime_verify"
                    class="btn-primary"/>
            <button name="action_approve" type="object" string="Approve"
                    invisible= "state != 'hr_verified'" 
                    groups="hr_plus.group_hr_plus_overtime_approve"
                    class="btn-primary"/>
            <button name="action_refuse" type="object" string="Refuse"
                    invisible="state in ['draft', 'submitted', 'approved', 'refused', 'cancelled']"
                    groups="hr_plus.group_hr_plus_overtime_approve"/>
            <button name="action_cancel" type="object" string="Cancel"
                    invisible="state in ['draft', 'cancelled']"
                    groups="hr_plus.group_hr_plus_overtime_verify"/>
            <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                    invisible="state in ['draft', 'hr_verified', 'approved', 'refused']"
                    groups="hr_plus.group_hr_plus_overtime_submit"/>
            <field name="state" widget="statusbar"
                  statusbar_visible="draft,submitted,hr_verified,approved"
                  statusbar_colors="{'refused':'red', 'cancelled':'orange'}" />
        </header>
        <sheet>
          <h1><field name="name"/></h1>
          
        
          <group>
            <group>
              <field name="manager_id" readonly="state not in ['draft', 'submitted']"/>
              <field name="date_from" readonly="state not in ['draft', 'submitted']"/>
              <field name="date_to" readonly="state not in ['draft', 'submitted']"/>
            </group>
            <group>
              <field name="reason" readonly="state not in ['draft', 'submitted']"/>
              <field name="total_ot_hours" readonly="1"/>
            </group>
          </group>
          <notebook>
            <page string="Requested For">
              <field name="line_ids" >
                <tree editable="bottom">
                  <field name="employee_id"/>
                  <field name="regular_ot"/>
                  <field name="late_night_ot"/>
                  <field name="weekend_ot"/>
                  <field name="holiday_ot"/>
                  <field name="reason"/>
                  <field name="payslip_id" readonly="1" />
                  
                </tree>
              </field>
            </page>
          </notebook>
          
        </sheet>
        
        <div class="oe_chatter">
            <field name="message_follower_ids"/>
            <field name="activity_ids"/>
            <field name="message_ids"/>
        </div>
      </form>
    </field>
    
  </record>

  <record id="view_hr_overtime_tree" model="ir.ui.view">
    <field name="name">hr.overtime.tree</field>
    <field name="model">hr.overtime</field>
    <field name="arch" type="xml">
      <tree>
        <field name="name"/>
        <field name="manager_id"/>
        <field name="date_from"/>
        <field name="date_to"/>
        <field name="state" widget="badge"
          decoration-info="state == 'submitted'" 
          decoration-success="state == 'approved'"
          decoration-primary="state == 'hr_verified'"
          decoration-warning="state == 'cancelled'"          
          decoration-danger="state == 'refused'"/>
      </tree>
    </field>
  </record>

  <record id="view_hr_overtime_line_tree" model="ir.ui.view">
    <field name="name">hr.overtime.line.tree</field>
    <field name="model">hr.overtime.line</field>
    <field name="arch" type="xml">
      <tree>
        <field name="employee_id"/>
        <field name="overtime_id"/>
        <field name="regular_ot"/>
        <field name="late_night_ot"/>
        <field name="weekend_ot"/>
        <field name="holiday_ot"/>
        <field name="reason"/>
        <field name="payslip_id" readonly="1" />
        <field name="state" widget="badge"
          decoration-info="state == 'submitted'" 
          decoration-success="state == 'approved'"
          decoration-primary="state == 'hr_verified'"
          decoration-warning="state == 'cancelled'"          
          decoration-danger="state == 'refused'"/>
      </tree>
    </field>
  </record>

  <record id="view_hr_overtime_line_form" model="ir.ui.view">
    <field name="name">hr.overtime.line.form</field>
    <field name="model">hr.overtime.line</field>
    <field name="arch" type="xml">
      <form>
        <group>
          <group>            
            <field name="overtime_id" readonly="state not in ['draft', 'submitted']"/>
            <field name="employee_id" readonly="state not in ['draft', 'submitted']"/>
            <field name="reason" readonly="state not in ['draft', 'submitted']"/>
            <field name="state" widget="badge" readonly="1"
              decoration-info="state == 'submitted'" 
              decoration-success="state == 'approved'"
              decoration-primary="state == 'hr_verified'"
              decoration-warning="state == 'cancelled'"          
              decoration-danger="state == 'refused'"/>
            
          </group>
          <group>
            <field name="regular_ot" readonly="state not in ['draft', 'submitted']"/>
            <field name="late_night_ot" readonly="state not in ['draft', 'submitted']"/>
            <field name="weekend_ot" readonly="state not in ['draft', 'submitted']"/>
            <field name="holiday_ot" readonly="state not in ['draft', 'submitted']"/>
          </group>         
            
        </group>
      </form>
    </field>
  </record>



  <record id="action_hr_overtime" model="ir.actions.act_window">
    <field name="name">Overtime Records</field>
    <field name="res_model">hr.overtime</field>
    <field name="view_mode">tree,form</field>
  </record>

  
  <menuitem id="menu_hr_overtime" name="Overtime" parent="menu_hr_plus_root" groups="hr_plus.group_hr_plus_overtime_submit" />
  <menuitem id="menu_hr_overtime_records" name="Overtime Records" parent="menu_hr_overtime" action="action_hr_overtime"/>
  <!-- <menuitem id="menu_hr_overtime_dashboard" name="Overtime Dashboard" parent="menu_hr_plus_root" action="action_hr_overtime_kanban"/> -->
  
  
</odoo>
