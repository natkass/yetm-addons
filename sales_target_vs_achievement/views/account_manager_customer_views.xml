
<odoo>
    <record id="view_account_manager_customer_form" model="ir.ui.view">
        <field name="name">account.manager.customer.form</field>
        <field name="model">account.manager.customer</field>
        <field name="arch" type="xml">
            <form string="Account Manager / Franchisee">
                <header>
                    <button name="action_toggle_state"
                            type="object"
                            string="Lock"
                            class="oe_highlight"
                            invisible= "state != 'draft'"/>
                    <button name="action_toggle_state"
                            type="object"
                            string="Unlock"
                            class="btn-secondary"
                            invisible= "state != 'locked'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,locked"/>
                </header>
                <sheet>
                    <h1><field name="name"/></h1>
                
                    <group>
                        <group>
                            <field name="account_man_id" readonly="state not in ['draft']"/>
                        </group>
                        <group>
                            <field name="customer_ids" widget="many2many_tags" 
                                    options="{'no_create': True, 'no_create_edit': True}"
                                    />
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
                
            </form>
        </field>
    </record>

    <record id="view_account_manager_customer_tree" model="ir.ui.view">
        <field name="name">account.manager.customer.tree</field>
        <field name="model">account.manager.customer</field>
        <field name="arch" type="xml">
            <tree>
                <field name="account_man_id"/>
                <field name="customer_ids" widget="many2many_tags"/>
                
                <field name="state" widget="badge"
                        decoration-info="state == 'draft'" 
                        decoration-primary="state == 'locked'"/>
            </tree>
        </field>
    </record>

    <record id="action_account_manager_customer" model="ir.actions.act_window">
        <field name="name">Account Manager Customers</field>
        <field name="res_model">account.manager.customer</field>
        <field name="view_mode">tree,form</field>
    </record>

    
    <menuitem id="menu_account_manager_customer_root"
              name="Configuration"
              parent="target_achieve_menu_sales_target_root"              
              groups="sales_target_vs_achievement.group_sales_request_marketing_manager"
              sequence="4"/>
    
    <menuitem id="menu_account_manager_customer_record"
              name="Assign Manager"
              parent="menu_account_manager_customer_root"
              action="action_account_manager_customer"
              groups="sales_target_vs_achievement.group_sales_request_marketing_manager"
              sequence="4"/>
</odoo>
