<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add smart button + Create Store Request button to MO form -->
    <record id="view_mrp_production_form_inherit_store_request" model="ir.ui.view">
        <field name="name">mrp.production.form.inherit.store.request</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">

            <!-- Smart button -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_store_requests"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-exchange"
                        invisible="store_request_count == 0">
                    <field name="store_request_count" widget="statinfo" string="Store Requests"/>
                </button>
            </xpath>

            <!-- Create Store Request button in header -->
            <xpath expr="//header" position="inside">
                <button name="action_open_store_request_wizard"
                        string="Create Store Request"
                        type="object"
                        class="btn-secondary"
                        invisible="state in ('draft', 'cancel')"/>
            </xpath>

            <!-- Restrict Cancel button to Manufacturing Admin -->
            <xpath expr="//button[@name='action_cancel'][@data-hotkey='x']" position="attributes">
                <attribute name="groups">mrp.group_mrp_manager</attribute>
            </xpath>

            <!-- Restrict all Produce / Produce All buttons to Manufacturing Admin -->
            <xpath expr="//button[@name='button_mark_done']" position="attributes">
                <attribute name="groups">mrp.group_mrp_manager</attribute>
            </xpath>

        </field>
    </record>

</odoo>
