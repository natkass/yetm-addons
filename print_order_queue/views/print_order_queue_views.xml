<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_print_order_queue_tree" model="ir.ui.view">
        <field name="name">print.order.queue.tree</field>
        <field name="model">print.order.queue</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="invoice_id" options="{'no_create': True}"/>
                <field name="pdf_filename"/>
                <field name="pdf_size"/>
                <field name="generation_method"/>
                <field name="generation_date"/>
                <field name="status" widget="badge" decoration-success="status == 'done'" decoration-warning="status == 'pending'" decoration-danger="status == 'error'"/>
                <field name="requested_by" options="{'no_create': True}"/>
            </tree>
        </field>
    </record>

    <record id="view_print_order_queue_form" model="ir.ui.view">
        <field name="name">print.order.queue.form</field>
        <field name="model">print.order.queue</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="download_pdf" type="object" string="Download PDF" class="btn-primary" invisible="not invoice_id"/>
                    <button name="view_invoice_pdf" type="object" string="View Invoice PDF" class="btn-secondary" invisible="not invoice_id"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="invoice_id" options="{'no_create': True}"/>
                            <field name="report_name"/>
                            <field name="generation_method"/>
                            <field name="generation_date"/>
                            <field name="requested_by" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="pdf_filename"/>
                            <field name="pdf_size" widget="integer"/>
                            <field name="source_url"/>
                            <field name="printer_name"/>
                            <field name="error_message" invisible="not error_message"/>
                        </group>
                    </group>
                    <group string="PDF Data" invisible="not pdf_data">
                        <field name="pdf_data" widget="binary" filename="pdf_filename"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_print_order_queue" model="ir.actions.act_window">
        <field name="name">Print Order Queue</field>
        <field name="res_model">print.order.queue</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_print_order_queue_root" name="Print Order Queue"/>
    <menuitem id="menu_print_order_queue" name="Print Orders" parent="menu_print_order_queue_root" action="action_print_order_queue"/>
</odoo>
