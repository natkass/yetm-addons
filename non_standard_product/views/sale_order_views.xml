<!-- views/sale_order_views.xml -->
<odoo>
    <record id="view_order_form_inherit_non_standard" model="ir.ui.view">
        <field name="name">sale.order.form.non.standard</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <header position="inside">
                <button name="action_open_non_standard" 
                type="object" 
                string="Non-Standard" 
                invisible="state !='draft'"
                class="btn-secondary"/>
            </header>
        </field>
    </record>
</odoo>