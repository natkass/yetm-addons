<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_order_form_inherit_fiscal" model="ir.ui.view">
        <field name="name">pos.order.form.inherit.fiscal</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_pickings"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-truck"
                        attrs="{'invisible': [('picking_count', '=', 0)]}">
                    <field name="picking_count" widget="statinfo" string="Pickings"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>