<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Main Menu -->
    <menuitem id="menu_non_standard_root"
              name="Non-Standards"
              parent="sale.sale_menu_root" 
              sequence="50"
              groups="non_standard_product.group_non_standard_manager"/>

    <!-- FOAM -->
    <menuitem id="menu_non_standard_foam"
              name="Foams"
              parent="menu_non_standard_root"/>

    <record id="view_non_standard_foam_tree" model="ir.ui.view">
        <field name="name">non.standard.foam.tree</field>
        <field name="model">non.standard.foam</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="view_non_standard_foam_form" model="ir.ui.view">
        <field name="name">non.standard.foam.form</field>
        <field name="model">non.standard.foam</field>
        <field name="arch" type="xml">
        <form>
            <header>
                <button name="action_verify" type="object" string="Verify"
                        invisible= "state != 'draft'" 
                        groups="non_standard_product.group_non_standard_manager"/>
                        
                <button name="action_lock" type="object" string="Lock"
                        invisible= "state != 'verify'" 
                        groups="non_standard_product.group_non_standard_manager"/>

                <button name="action_cancel" type="object" string="Cancel"
                        invisible="state in ['draft', 'cancel']"
                        groups="non_standard_product.group_non_standard_manager"/>

                <button name="action_draft" type="object" string="Set to Draft"
                        invisible="state in ['draft', 'verify', 'lock']"
                        groups="non_standard_product.group_non_standard_manager"/>
                
                <field name="state" widget="statusbar"
                    statusbar_visible="draft,verify,lock"
                    statusbar_colors="{'refused':'red', 'cancelled':'orange'}" />
            </header>
            
                <sheet>
                    <group>
                        <field name="name" readonly="state not in ['draft', 'verify']"/>
                        
                    </group>
                    <notebook>
                        <page string="Values">
                            <field name="value_ids" readonly="state not in ['draft', 'verify']">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="unit_price"/>
                                </tree>
                            </field>    
                        </page>
                                
                        <page string="BOM Products">
                            <field name="product_ids" readonly="state not in ['draft', 'verify']">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="bom_factor"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                                    
                    
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
        </form>
        </field>
    </record>

    <record id="action_non_standard_foam" model="ir.actions.act_window">
        <field name="name">Foams</field>
        <field name="res_model">non.standard.foam</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_non_standard_foam_action"
              parent="menu_non_standard_root"
              action="action_non_standard_foam"/>

