<odoo>
  <!-- Category -->
  <record id="module_category_hr_plus" model="ir.module.category">
    <field name="name">HR Plus</field>
    <field name="description">Access rights for HR Plus features</field>
    <field name="sequence">20</field>
  </record>

  <!-- Submitter -->
  <record id="group_hr_plus_overtime_submit" model="res.groups">
    <field name="name">HR Plus OT Submit</field>
    <field name="category_id" ref="hr_plus.module_category_hr_plus"/>
  </record>

  <!-- Verifier -->
  <record id="group_hr_plus_overtime_verify" model="res.groups">
    <field name="name">HR Plus OT Verify</field>
    <field name="category_id" ref="hr_plus.module_category_hr_plus"/>
    <field name="implied_ids" eval="[(4, ref('hr_plus.group_hr_plus_overtime_submit'))]"/>
  </record>

  <!-- Approver -->
  <record id="group_hr_plus_overtime_approve" model="res.groups">
    <field name="name">HR Plus OT Approve</field>
    <field name="category_id" ref="hr_plus.module_category_hr_plus"/>
