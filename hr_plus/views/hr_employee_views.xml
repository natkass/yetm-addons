<odoo>
    <record id="view_hr_employee_form_inherit_overtime" model="ir.ui.view">
        <field name="name">hr.employee.tree.inherit.overtime</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/div[@name='button_box']" position="inside">
            <button name="action_view_overtime_lines" type="object" string="Overtime"
                    invisible="overtime_line_count == 0"
                    class="oe_stat_button" icon="fa-clock-o">
                <field name="overtime_line_count" string="Overtime" widget="statinfo"/>
            </button>
            </xpath>
        </field>
    </record>

