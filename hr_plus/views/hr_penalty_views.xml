<odoo>
    <record id="view_hr_penalty_form" model="ir.ui.view">
        <field name="name">hr.penalty.form</field>
        <field name="model">hr.penalty</field>
        <field name="arch" type="xml">
            <form string="Penalty">
                <header>
                    <button name="action_submit" type="object" string="Submit"
                            invisible= "state != 'draft'" 
                            groups="hr_plus.group_hr_plus_penalty_submit"
                            class="btn-primary"/>
                            
                    <button name="action_verify" type="object" string="Verify"
                            invisible= "state != 'submitted'" 
                            groups="hr_plus.group_hr_plus_penalty_verify"
                            class="btn-primary"/>
                    <button name="action_approve" type="object" string="Approve"
                            invisible= "state != 'hr_verified'" 
                            groups="hr_plus.group_hr_plus_penalty_approve"
                            class="btn-primary"/>
                    <button name="action_refuse" type="object" string="Refuse"
                            invisible="state in ['draft', 'submitted', 'approved', 'refused', 'cancelled']"
                            groups="hr_plus.group_hr_plus_penalty_approve"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ['draft', 'cancelled']"
                            groups="hr_plus.group_hr_plus_penalty_verify"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                            invisible="state in ['draft', 'hr_verified', 'approved', 'refused']"
                            groups="hr_plus.group_hr_plus_penalty_submit"/>
                    <button name="action_compute_payments" type="object" string="Compute Payments"
                            invisible="state != 'draft'" class="btn-primary"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,submitted,hr_verified,approved"
                        statusbar_colors="{'refused':'red', 'cancelled':'orange'}" />
                </header>
                <sheet>
                    <h1><field name="name"/></h1>
                    <group>
                        <group>
                        
                            <field name="employee_id" readonly="state not in ['draft', 'submitted']"/>
                            
                            <field name="amount" readonly="state not in ['draft', 'submitted']"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="start_date" readonly="state not in ['draft', 'submitted']"/>
                            
                        </group>
                        <group>
                            <field name="type" readonly="state not in ['draft', 'submitted']"/>  
                            <field name="months" invisible= "type != 'b'" readonly="state not in ['draft', 'submitted']"/>
                            <field name="reason" readonly="state not in ['draft', 'submitted']"/> 
                                    
                        </group>

                    </group>

                    <group>                           
                            
                        
                                    
                    </group>

                    <notebook>
                        <page string="Installment Schedule" readonly="1">
                            <field name="penalty_line_ids">
                                <tree editable="bottom">
                                <field name="payment_date"/>
                                <field name="amount"/>
                                <field name="is_paid" readonly="1"/>
                                <field name="payslip_id" readonly="1"/>
                                <field name="state" readonly="1"/>
                                </tree>
                            </field>
                        </page>                        
                    </notebook>

                    <group string="Payment Summary" col="2">
                        <field name="paid_amount" readonly="1"/>
                        <field name="remaining_amount" readonly="1"/>
                        <field name="is_completed" readonly="1"/>
                                                
                    </group>

                    
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>

            
            </form>
        </field>
    </record>

    <record id="view_hr_penalty_tree" model="ir.ui.view">
        <field name="name">hr.penalty.tree</field>
        <field name="model">hr.penalty</field>
        <field name="arch" type="xml">
        <tree>
            <field name="name"/>
            <field name="employee_id"/>
            <field name="type"/>
            <field name="amount"/>            
            <field name="paid_amount"/>
            <field name="remaining_amount"/>
            <field name="state" widget="badge"
                decoration-info="state == 'submitted'" 
                decoration-success="state == 'approved'"
                decoration-primary="state == 'hr_verified'"
                decoration-warning="state == 'cancelled'"          
                decoration-danger="state == 'refused'"/>
        </tree>
        </field>
    </record>

    <record id="view_hr_penalty_line_form" model="ir.ui.view">
        <field name="name">hr.penalty.line.form</field>
        <field name="model">hr.penalty.line</field>
        <field name="arch" type="xml">
        <form>
            <group>
                <group>
                    <field name="penalty_id" readonly="1"/>
                    <field name="employee_id" readonly="1"/>
                    <field name="payment_date" readonly="1"/>
                    <field name="type" readonly="1"/>
                    <field name="amount" readonly="1"/>  
                    <field name="reason" readonly="1"/> 
                </group>
                <group>         
                    <field name="is_paid" readonly="1"/>                    
                    <field name="state" widget="badge" readonly="1"
                        decoration-info="state == 'submitted'" 
                        decoration-success="state == 'approved'"
                        decoration-primary="state == 'hr_verified'"
                        decoration-warning="state == 'cancelled'"          
                        decoration-danger="state == 'refused'"/>
                </group>
            </group>
        </form>
        </field>
    </record>


    <record id="view_hr_penalty_line_tree" model="ir.ui.view">
        <field name="name">hr.penalty.line.tree</field>
        <field name="model">hr.penalty.line</field>
        <field name="arch" type="xml">
        <tree>
            <field name="penalty_id"/>
            <field name="employee_id"/>
            <field name="payment_date"/>
            <field name="type"/>
            <field name="amount"/>            
            <field name="is_paid"/>            
            <field name="state" widget="badge"
                decoration-info="state == 'submitted'" 
                decoration-success="state == 'approved'"
                decoration-primary="state == 'hr_verified'"
                decoration-warning="state == 'cancelled'"          
                decoration-danger="state == 'refused'"/>
        </tree>
        </field>
    </record>


    <record id="action_hr_penalty" model="ir.actions.act_window">
        <field name="name">Penalties</field>
        <field name="res_model">hr.penalty</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_hr_penalty" name="Penalties" parent="menu_hr_plus_root" sequence="40" groups="hr_plus.group_hr_plus_penalty_submit"/>
    <menuitem id="menu_hr_penalty_records" name="Employee Penalties" parent="menu_hr_penalty" action="action_hr_penalty"/>
</odoo>
