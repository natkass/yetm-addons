<odoo>
    <record id="view_manufacturing_request_wizard_form" model="ir.ui.view">
        <field name="name">manufacturing.request.wizard.form</field>
        <field name="model">manufacturing.request.wizard</field>
        <field name="arch" type="xml">
            <form string="Manufacturing Request">
                <group>
                    <group>
                        
                        <field name="partner_id" options="{'no_create': True, 'no_open': True}"/>
                        <field name="customer_phone"/>
                        <field name="promise_date"/>
                        
                        
                    </group>
                    <group>
                        
                        <field name="production_location_id" options="{'no_create': True, 'no_open': True}"/>
                        <field name="branch_id" options="{'no_create': True, 'no_open': True}"/>
                        <field name="responsible_id" options="{'no_create': True, 'no_open': True}"/>
                    </group>
                </group>
                <footer>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
