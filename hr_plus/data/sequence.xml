      <field name="code">hr.penalty</field>
      <field name="prefix">PEN/</field>
      <field name="padding">4</field>
    </record>
  </data>

  <data noupdate="1">
    <record id="seq_hr_loan" model="ir.sequence">
      <field name="name">Loan</field>
      <field name="code">hr.loan</field>
      <field name="prefix">LOAN/</field>
      <field name="padding">4</field>
    </record>
  </data>

  <data noupdate="1">
    <record id="seq_hr_advance" model="ir.sequence">
      <field name="name">Advance</field>
      <field name="code">hr.advance</field>
      <field name="prefix">ADVANCE/</field>
      <field name="padding">4</field>
    </record>
  </data> 
</odoo>
