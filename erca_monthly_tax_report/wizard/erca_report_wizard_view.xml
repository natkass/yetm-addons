<odoo>
  <record id="view_erca_monthly_tax_wizard_form" model="ir.ui.view">
    <field name="name">erca.monthly.tax.wizard.form</field>
    <field name="model">erca.monthly.tax.wizard</field>
    <field name="arch" type="xml">
      <form string="ERCA Monthly Tax Report">
        <group>
          <field name="date_from"/>
          <field name="date_to"/>
        </group>
        <footer>
          <button name="generate_report" type="object" string="Export Excel" class="btn-primary"/>
          <button string="Cancel" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_erca_monthly_tax_wizard" model="ir.actions.act_window">
    <field name="name">ERCA Monthly Tax Report</field>
    <field name="res_model">erca.monthly.tax.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>

  <menuitem id="menu_erca_tax_report"
          name="ERCA Monthly Tax Report"
          parent="account.menu_finance_reports"
          action="action_erca_monthly_tax_wizard"
          sequence="20"/>

</odoo>
