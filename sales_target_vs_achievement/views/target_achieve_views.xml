<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--        Tree view of Target and achieved details based on each individual-->
    <record id="target_achieve_view_tree_user" model="ir.ui.view">
        <field name="name">target.achieve.view.tree.user</field>
        <field name="model">target.achieve</field>
        <field name="arch" type="xml">
            <tree string="Franchisee Target Achieved Details">
                <field name="currency_id" invisible="1"/>
                <field name="name"/>
                <field name="franchisee_id"/>
                <field name="franchisee_target" widget="monetary"/>
                <field name="franchisee_achieved_amt" widget="monetary"/>
                
                
                <field name="time_span_label" readonly="1"/>
                <field name="acc_man_id"/>                
                <field name="franchisee_achieved_percent" widget="progressbar" 
                                    options="{'max_field': '100'}"/>
            </tree>
        </field>
    </record>

    <!--        Form view to set Target and show achieved details based on each Franchisee-->
    <record id="target_achieve_view_form" model="ir.ui.view">
        <field name="name">target.achieve.view.form</field>
        <field name="model">target.achieve</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm"
                            type="object"
                            string="Confirm"
                            class="oe_highlight"
                            invisible= "state != 'draft'"/>
                    <button name="action_cancel"
                            type="object"
                            string="Cancel"
                            class="btn-secondary"
                            invisible= "state != 'submit'"/>

                    <button name="action_recompute"
                            type="object"
                            string="Refresh"
                            class="btn-secondary"
                            />
                    <field name="state" widget="statusbar" statusbar_visible="draft,submit"/>
                
                </header>
                
            
                <sheet>

                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_franchisee_orders"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-shopping-cart"
                                invisible= "sale_order_count == 0">
                            <field name="sale_order_count" widget="statinfo"/>
                        </button>

                        <button name="action_view_franchisee_pos_orders"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-shopping-cart"
                                invisible= "pos_order_count == 0">
                            <field name="pos_order_count" widget="statinfo"/>
                        </button>

                    </div>
                    <h1><field name="name"/></h1>

                    <group>
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="franchisee_id" readonly= "state != 'draft'" options="{'no_create': True, 'no_create_edit': True}"/>
                            
                            <field name="time_span" readonly= "state != 'draft'"/>
                            <field name="selected_date" readonly= "state != 'draft'"/>
                            <field name="time_span_label" readonly="1"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            
                        </group>
                        <group>
                            <field name="franchisee_target" widget="monetary"/>
                            <field name="franchisee_achieved_amt"
                                   widget="monetary"/>
                            <field name="franchisee_achieved_percent" widget="progressbar" 
                                    options="{'max_field': '100'}"/>                           
                            
                            <field name="acc_man_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Categorized Targets">
                            <field name="line_ids" readonly= "state != 'draft'">
                                <tree editable="bottom">
                                    <field name="category_id" options="{'no_create': True, 'no_create_edit': True}"/>
                                    <field name="target_amount"/>
                                    <field name="achieved_amount"/>
                                    
                                    <field name="achieved_percent" widget="progressbar" 
                                    options="{'max_field': '100'}"/>
                                </tree>
                                
                            </field>
                        </page>
                        <page string="Products Summary">
                            <field name="product_summary_ids" readonly="1">
                                <tree>
                                    <field name="product_id"/>
                                    <field name="total_qty"/>
                                    <field name="total_amount"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                    <field name="activity_ids"/>
                </div>
            </form>
        </field>
    </record>

        <!--        Tree view of Target and achieved details based on each Account Manager-->
    <record id="target_achieve_view_tree_team" model="ir.ui.view">
        <field name="name">target.achieve.manager.view.tree</field>
        <field name="model">target.achieve.manager</field>
        <field name="arch" type="xml">
            <tree string="Account Manager Target Achieved Details">
                <field name="currency_id" invisible="1"/>
                
                <field name="acc_man_id"/>
                <field name="acc_man_achieved_amt" widget="monetary"/>
                <field name="acc_man_target" force_save="1"/>
                
                <field name="time_span_label"/>
                
                <field name="acc_man_achieved_percent" widget="progressbar" 
                                    options="{'max_field': '100'}"/>
                
            </tree>
        </field>
    </record>

    <!--        Form view to set Target and show achieved details based on each Account MAnager-->
    <record id="target_achieve_manager_view_form" model="ir.ui.view">
        <field name="name">target.achieve.manager.view.form</field>
        <field name="model">target.achieve.manager</field>
        <field name="arch" type="xml">
            <form>
               
                <header>
                    <button name="action_confirm"
                            type="object"
                            string="Confirm"
                            class="oe_highlight"
                            invisible= "state != 'draft'"/>
                    <button name="action_cancel"
                            type="object"
                            string="Cancel"
                            class="btn-secondary"
                            invisible= "state != 'submit'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submit"/>
                    
                </header>

                <sheet>
                    <h1><field name="name" /></h1>
                    <group>
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="acc_man_id"/>
                            
                            <field name="selected_date"/>
                            <field name="time_span"/>
                            <field name="time_span_label" readonly="1"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                           
                        </group>
                        <group>
                            <field name="acc_man_target" widget="monetary"/>
                            <field name="acc_man_achieved_amt"
                                   widget="monetary"/>
                            <field name="acc_man_achieved_percent" widget="progressbar" 
                                    options="{'max_field': '100'}"/>
                            
                            <!-- <field name="name" /> -->
                        </group>
                    </group>
                    <notebook>
                        
                        <page string="Assigned Targets">
                            <field name="target_record_ids">
                                <tree>
                                    <field name="franchisee_id"/>
                                    <field name="franchisee_target"/>
                                    <field name="franchisee_achieved_amt"/>
                                    <field name="time_span_label"/>
                                    <field name="franchisee_achieved_percent" widget="progressbar" 
                                                options="{'max_field': '100'}"/>

                                </tree>
                            </field>
                        </page>
                    </notebook>
                    
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                    <field name="activity_ids"/>
                </div>
            </form>
        </field>
    </record>
    <!--        Search view -->
    <record id="target_achieve_view_search" model="ir.ui.view">
        <field name="name">target.achieve.view.search</field>
        <field name="model">target.achieve</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="franchisee_id"/>
                <field name="time_span"/>
                <field name="acc_man_id"/>
                <filter string="Account Manager Target" name="team"
                        context="{'group_by':'acc_man_id'}"/>
                <filter string="Franchisee Target" name="user"
                        context="{'group_by':'franchisee_id'}"/>
            </search>
        </field>
    </record>
    <!--        Graph view-->
    <record id="target_achieve_view_graph" model="ir.ui.view">
        <field name="name">target.achieve.view.graph</field>
        <field name="model">target.achieve</field>
        <field name="type">graph</field>
        <field name="arch" type="xml">
            <graph string="Target Achieved Details" type="bar">
                <field name="franchisee_id"/>
                <field name="franchisee_achieved_amt" />
                
            </graph>
        </field>
    </record>
    <!--    Action for the User Target Achieved Details Menu-->
    <record id="target_achieve_action_user" model="ir.actions.act_window">
        <field name="name">Franchisee Targets</field>
        <field name="res_model">target.achieve</field>
        <field name="context">{"search_default_user":1}</field>
        <field name="view_ids" eval="[(5, 0, 0),
        (0, 0, {'view_mode': 'tree', 'view_id': ref('target_achieve_view_tree_user')}),
        (0, 0, {'view_mode': 'form', 'view_id': ref('target_achieve_view_form')}),
        ]"/>
        <field name="view_mode">tree</field>
    </record>
    <!--        Action for the Team Target Achieved Details Menu-->
    <record id="target_achieve_action_team" model="ir.actions.act_window">
        <field name="name">Account Manager Targets</field>
        <field name="res_model">target.achieve.manager</field>
        <field name="context">{"search_default_team":1}</field>
        <field name="view_ids" eval="[(5, 0, 0),
    (0, 0, {'view_mode': 'tree', 'view_id': ref('target_achieve_view_tree_team')}),
    (0, 0, {'view_mode': 'form', 'view_id': ref('target_achieve_manager_view_form')}),
    ]"/>
        <field name="view_mode">tree</field>
    </record>
    <!--    Action for the Graph view to show-->
    <record id="target_achieve_action_graph" model="ir.actions.act_window">
        <field name="name">Target Achieve Graph</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">target.achieve</field>
        <field name="view_mode">graph</field>
    </record>

    
    
    <menuitem id="target_achieve_menu_sales_target_root"
              name="Franchise Management"              
              sequence="6"
              groups="sales_target_vs_achievement_group_sales_target_user"
              web_icon= "sales_target_vs_achievement,static\description\icon.png"/>
    <menuitem id="target_achieve_menu_sales_target"
              name="Franchise Target"
              parent="target_achieve_menu_sales_target_root" 
              groups="sales_target_vs_achievement_group_sales_target_user"             
              sequence="1"
              />
    <menuitem id="target_achieve_menu_target_achieve_team"
              name="Account Manager Targets"
              parent="target_achieve_menu_sales_target"
              action="target_achieve_action_team"
              groups="sales_target_vs_achievement_group_sales_target_user"
              sequence="3"/>
    <menuitem id="target_achieve_menu_target_achieve_user"
              name="Franchisee Targets"
              parent="target_achieve_menu_sales_target"
              action="target_achieve_action_user"
              groups="sales_target_vs_achievement_group_sales_target_user"
              sequence="2"/>
    <menuitem id="target_achieve_menu_target_achieve_analysis"
              name="Target and Achievement Analysis"
              parent="target_achieve_menu_sales_target"
              action="target_achieve_action_graph"
              groups="sales_target_vs_achievement_group_sales_target_user"
              sequence="1"/>
</odoo>
