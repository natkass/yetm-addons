<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_peachtree_customer_product_export_wizard_form" model="ir.ui.view">
        <field name="name">peachtree.customer.product.export.wizard.form</field>
        <field name="model">peachtree.customer.product.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Export Customers/Products to Peachtree">
                <group invisible="state != 'draft'">
                    <group string="Export Settings">
                        <field name="export_type" widget="radio"/>
                    </group>
                    <group string="Filters">
                        <field name="customer_filter"
                               invisible="export_type != 'customer'"/>
                        <field name="product_filter"
                               invisible="export_type != 'product'"/>
                    </group>
                    <group string="Options">
                        <field name="only_unexported"/>
                        <field name="mark_as_exported"/>
                    </group>
                </group>
                <group invisible="state != 'done'">
                    <group>
                        <field name="export_count"/>
                        <field name="csv_file" filename="csv_filename"/>
                        <field name="csv_filename" invisible="1"/>
                    </group>
                </group>
                <field name="state" invisible="1"/>
                <footer>
                    <button name="action_export"
                            string="Export to CSV"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_reset"
                            string="Export Again"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'done'"/>
                    <button name="action_reset_exported_flag"
                            string="Reset Exported Flag"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'draft'"
                            confirm="This will mark all exported records of the selected type as unexported. Continue?"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_peachtree_customer_product_export_wizard" model="ir.actions.act_window">
        <field name="name">Export Customers/Products to Peachtree</field>
        <field name="res_model">peachtree.customer.product.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
