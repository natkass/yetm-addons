<odoo>
    <record id="view_hr_advance_report_wizard_form" model="ir.ui.view">
        <field name="name">hr.advance.report.wizard.form</field>
        <field name="model">hr.advance.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Advance Report">
                <group>
                    <group>
                        <field name="start_date"/>
                        <field name="end_date"/>
                    </group>

                    <group>
                        <field name="location_id"/>
                    </group>
                </group>
                <footer>
                    <button string="Generate Excel Report" type="object" name="action_generate_report" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
                <group>
                    <field name="file_name" invisible="1"/>
                    <field name="file_data" invisible="1"/>
                </group>
            </form>
        </field>
    </record>

    <record id="action_hr_advance_report_wizard" model="ir.actions.act_window">
        <field name="name">Advance Report</field>
        <field name="res_model">hr.advance.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_hr_advance_report"
              name="Advance Report"
              parent="hr_plus.menu_hr_advance"
              action="action_hr_advance_report_wizard"
              groups="group_hr_plus_advance_approve"
              sequence="20"/>
</odoo>
