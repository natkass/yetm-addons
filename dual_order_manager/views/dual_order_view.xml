<odoo>
    <record id="view_dual_order_form" model="ir.ui.view">
        <field name="name">dual.order.form</field>
        <field name="model">dual.order</field>
        <field name="arch" type="xml">
            <form string="Dual Order">
                <header>
                    <button name="action_confirm" type="object" string="Confirm" class="btn-primary"
                            />
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_sale_order" type="object" class="oe_stat_button"
                                icon="fa-shopping-cart"
                               >
                            <field name="sale_order_id" invisible="1"/>
                            <div class="o_stat_info">
                                <span class="o_stat_text">Sales Order</span>
                            </div>
                        </button>

                        <button name="action_view_picking" type="object" class="oe_stat_button"
                                icon="fa-truck"
                                >
                            <field name="picking_id" invisible="1"/>
                            <div class="o_stat_info">
                                <span class="o_stat_text">Delivery Order</span>
                            </div>
                        </button>
                    </div>

                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="name" readonly="1" string="Order Reference"/>
                        </group>
                        <group>
                            <field name="create_date" readonly="1" string="Order Date"/>
                            <field name="state" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Order Lines">
                            <field name="order_line_ids" nolabel="1">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="product_uom_qty"/>
                                    <field name="price_unit"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Other Info">
                            <group>
                                <field name="sale_order_id" readonly="1"/>
                                <field name="picking_id" readonly="1"/>
                            </group>
                        </page>
                    </notebook>

                </sheet>
                <!-- ✅ Add Chatter Section -->
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
</odoo>
