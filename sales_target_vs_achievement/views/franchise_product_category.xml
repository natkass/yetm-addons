
<odoo>
    <record id="view_franchise_product_category_form" model="ir.ui.view">
        <field name="name">franchise.product.category.form</field>
        <field name="model">franchise.product.category</field>
        <field name="arch" type="xml">
            <form string="Account Manager / Franchisee">
                <header>
                    <button name="action_toggle_state"
                            type="object"
                            string="Lock"
                            class="oe_highlight"
                            invisible= "state != 'draft'"/>
                    <button name="action_toggle_state"
                            type="object"
                            string="Unlock"
                            class="btn-secondary"
                            invisible= "state != 'locked'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,locked"/>
                </header>
                <sheet>
                    
                
                    <group>
                        <group>
                            <field name="name" readonly="state not in ['draft']" />
                        </group>
                        <group>
                            <field name="product_tag_id" widget="many2many_tags" readonly="state not in ['draft']"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
                
            </form>
        </field>
    </record>

    <record id="view_franchise_product_category_tree" model="ir.ui.view">
        <field name="name">franchise.product.category.tree</field>
        <field name="model">franchise.product.category</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="product_tag_id" widget="many2many_tags" options="{'no_create': True, 'no_create_edit': True}"/>
                
                <field name="state" widget="badge"
                        decoration-info="state == 'draft'" 
                        decoration-primary="state == 'locked'"/>
            </tree>
        </field>
    </record>

    <record id="action_franchise_product_category" model="ir.actions.act_window">
        <field name="name">Franchise Product Category</field>
        <field name="res_model">franchise.product.category</field>
        <field name="view_mode">tree,form</field>
    </record>

    
        
    <menuitem id="menu_franchise_product_category_record"
              name="Franchise Product Category"
              parent="menu_account_manager_customer_root"
              action="action_franchise_product_category"
              groups="sales_target_vs_achievement.group_sales_request_sales_manager,sales_target_vs_achievement.group_sales_request_marketing_manager"
              sequence="4"/>
</odoo>
