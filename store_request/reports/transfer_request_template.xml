<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_transfer_request_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center" style="margin-bottom: 40px;">
                            <strong>Store Request</strong>
                        </h2>

                        <!-- Header Information -->
                        <div class="row mt32 mb32">
                            <div class="col-6">
                                <strong>Reference:</strong> <span t-field="o.name"/>
                                <t t-if="o.stock_picking">
                                    | <strong>Transfer:</strong> <span t-field="o.stock_picking.name"/>
                                </t><br/>
                                <strong>Status:</strong> <span t-field="o.state"/><br/>
                                <strong>Creation Date:</strong> <span t-field="o.date"/><br/>
                                <strong>Scheduled Date:</strong> <span t-field="o.scheduled_date"/>
                            </div>
                            <div class="col-6">
                                <strong>Operation Type:</strong> <span t-field="o.picking_type_id.name"/><br/>
                                <strong>Source Location:</strong> <span t-field="o.location_id.complete_name"/><br/>
                                <strong>Destination Location:</strong> <span t-field="o.location_dest_id.complete_name"/>
                            </div>
                        </div>

                        <!-- Items Table -->
                        <table class="table table-sm o_main_table" style="margin-top: 20px;">
                            <thead>
                                <tr>
                                    <th style="text-align: left;">Product</th>
                                    <th style="text-align: left;">Demand</th>
                                    <th style="text-align: left;">Sent</th>
                                    <th style="text-align: left;">Received</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.item_ids" t-as="line">
                                    <tr>
                                        <td style="text-align: left;"><span t-field="line.product_id.display_name"/></td>
                                        <td style="text-align: left;">
                                            <span t-field="line.demand"/>
                                        </td>
                                        <td style="text-align: left;">
                                            <span t-field="line.sent"/>
                                        </td>
                                        <td style="text-align: left;">
                                            <span t-field="line.received"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- Notes Section -->
                        <t t-if="o.note">
                            <div class="row mt32">
                                <div class="col-12">
                                    <strong>Notes:</strong>
                                    <p t-field="o.note"/>
                                </div>
                            </div>
                        </t>

                        <!-- Signature Section - Vertical Layout -->
                        <div style="margin-top: 500px;">
                            <!-- Requested By -->
                            <div style="margin-bottom: 30px;">
                                <table style="width: 100%; border: none;" border="0">
                                    <tr>
                                        <td style="width: 30%; border: none; padding: 5px; vertical-align: middle;">
                                            <strong>Requested By:</strong>
                                        </td>
                                        <td style="width: 30%; border: none; padding: 5px; vertical-align: middle;">
                                            <span t-field="o.user_id.name"/>
                                        </td>
                                        <td style="width: 20%; border: none; padding: 5px; vertical-align: middle;">
                                            <t t-if="o.user_id">
                                                Date: <span t-field="o.date" t-options='{"widget": "date"}'/>
                                            </t>
                                        </td>
                                        <td style="width: 20%; border: none; padding: 5px; vertical-align: middle;">
                                            Signature: ______________
                                        </td>
                                    </tr>
                                </table>
                            </div>

                            <!-- Approved By -->
                            <div style="margin-bottom: 30px;">
                                <table style="width: 100%; border: none;" border="0">
                                    <tr>
                                        <td style="width: 30%; border: none; padding: 5px; vertical-align: middle;">
                                            <strong>Approved By:</strong>
                                        </td>
                                        <td style="width: 30%; border: none; padding: 5px; vertical-align: middle;">
                                            <span t-field="o.approved_id.name"/>
                                        </td>
                                        <td style="width: 20%; border: none; padding: 5px; vertical-align: middle;">
                                            <t t-if="o.approved_date">
                                                Date: <span t-field="o.approved_date" t-options='{"widget": "date"}'/>
                                            </t>
                                            <t t-if="not o.approved_date">
                                                Date: ______________
                                            </t>
                                        </td>
                                        <td style="width: 20%; border: none; padding: 5px; vertical-align: middle;">
                                            Signature: ______________
                                        </td>
                                    </tr>
                                </table>
                            </div>

                            <!-- Received By -->
                            <div style="margin-bottom: 30px;">
                                <table style="width: 100%; border: none;" border="0">
                                    <tr>
                                        <td style="width: 30%; border: none; padding: 5px; vertical-align: middle;">
                                            <strong>Received By:</strong>
                                        </td>
                                        <td style="width: 30%; border: none; padding: 5px; vertical-align: middle;">
                                            <span t-field="o.received_id.name"/>
                                        </td>
                                        <td style="width: 20%; border: none; padding: 5px; vertical-align: middle;">
                                            <t t-if="o.received_date">
                                                Date: <span t-field="o.received_date" t-options='{"widget": "date"}'/>
                                            </t>
                                            <t t-if="not o.received_date">
                                                Date: ______________
                                            </t>
                                        </td>
                                        <td style="width: 20%; border: none; padding: 5px; vertical-align: middle;">
                                            Signature: ______________
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- Purchase Request Link if exists - Horizontal -->
                        <!-- <t t-if="o.purchase_request_id">
                            <div style="margin-top: 20px;">
                                <strong>Related Purchase Request:</strong>
                                <span t-field="o.purchase_request_id.name"/>
                            </div>
                        </t> -->

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
